{
  "workflow_id": "tax-audit-flow-001",
  "name": "标准出海企业合规入账流",
  "version": "2026.1",
  "nodes": [
    {
      "id": "node_1",
      "type": "OCR_RECOGNITION",
      "name": "智能票据感知",
      "config": { "engine": "gemini-3-flash", "extract_fields": ["code", "date", "amount"] }
    },
    {
      "id": "node_2",
      "type": "RISK_VALIDATION",
      "name": "双重合规预警",
      "params": { "check_duplicate": true, "sta_verify": "async" },
      "on_failure": "BLOCK_AND_ALERT"
    },
    {
      "id": "node_3",
      "type": "RAG_POLICY_MATCH",
      "name": "实时政策检索",
      "config": { "knowledge_base": "docs/tax_2026", "region": "CN_MAINLAND" }
    },
    {
      "id": "node_4",
      "type": "AUTO_ACCOUNTING",
      "name": "全自动记账/凭证",
      "config": { "ledger_standard": "IFRS_US_GAAP" }
    }
  ],
  "edges": [
    { "from": "node_1", "to": "node_2", "condition": "success" },
    { "from": "node_2", "to": "node_3", "condition": "is_unique == true" },
    { "from": "node_3", "to": "node_4", "condition": "tax_rate_confirmed" }
  ]
}